---
interface Props {
  isReader?: boolean;
}

const { isReader = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

{!isReader && (
  <nav class="fixed left-0 right-0 top-0 z-50 border-b border-transparent bg-transparent py-5 transition-all duration-300" id="main-navbar">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6">
      <!-- LOGO -->
      <a href="/" class="group flex items-center gap-2.5">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-stone-800 text-white transition-transform group-hover:scale-105 dark:bg-stone-700">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <span class="text-lg font-semibold tracking-tight text-stone-900 dark:text-stone-100">
          Manov
        </span>
      </a>

      <!-- DESKTOP MENU -->
      <div class="hidden items-center gap-6 md:flex">
        <a
          href="/"
          class={`text-sm font-medium transition hover:text-stone-900 dark:hover:text-stone-100 ${currentPath === '/' ? 'text-stone-900 dark:text-stone-100' : 'text-stone-600 dark:text-stone-400'}`}
        >
          Home
        </a>
        <a
          href="/library"
          class={`text-sm font-medium transition hover:text-stone-900 dark:hover:text-stone-100 ${currentPath === '/library' ? 'text-stone-900 dark:text-stone-100' : 'text-stone-600 dark:text-stone-400'}`}
        >
          Library
        </a>
        <a
          href="/about"
          class={`text-sm font-medium transition hover:text-stone-900 dark:hover:text-stone-100 ${currentPath === '/about' ? 'text-stone-900 dark:text-stone-100' : 'text-stone-600 dark:text-stone-400'}`}
        >
          About
        </a>

        <slot name="theme" />
        <slot name="notifications" />
        <slot name="auth" />
      </div>

      <!-- MOBILE TOGGLE -->
      <button
        class="text-stone-800 dark:text-stone-100 md:hidden"
        id="mobile-menu-toggle"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </nav>
)}

<script>
  // Scroll behavior for navbar
  const navbar = document.getElementById('main-navbar');
  if (navbar) {
    const handleScroll = () => {
      if (window.scrollY > 20) {
        navbar.classList.add('border-stone-200', 'bg-white/90', 'py-3', 'backdrop-blur-xl', 'dark:border-white/5', 'dark:bg-[#1c1917]/90');
        navbar.classList.remove('border-transparent', 'bg-transparent', 'py-5');
      } else {
        navbar.classList.remove('border-stone-200', 'bg-white/90', 'py-3', 'backdrop-blur-xl', 'dark:border-white/5', 'dark:bg-[#1c1917]/90');
        navbar.classList.add('border-transparent', 'bg-transparent', 'py-5');
      }
    };
    window.addEventListener('scroll', handleScroll);
    handleScroll();
  }
</script>
