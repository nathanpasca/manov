---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  jsonLd?: Record<string, any>;
  noindex?: boolean;
  type?: string;
  author?: string;
  tags?: string[];
  publishedAt?: string;
  modifiedAt?: string;
}

const {
  title,
  description,
  ogImage,
  canonical,
  jsonLd,
  noindex = false,
  type = 'website',
  author,
  tags = [],
  publishedAt,
  modifiedAt,
} = Astro.props;

const siteName = 'Manov';
const siteUrl = import.meta.env.PUBLIC_FRONTEND_URL || 'https://manov.pascarz.site';
const twitterHandle = '@manovnovels';

const fullTitle = title ? `${title} | ${siteName}` : siteName;
const defaultDescription =
  'Read translated web novels. Free, unlimited chapters. Discover trending stories updated daily.';
const metaDescription = description || defaultDescription;

const metaImage = ogImage
  ? ogImage.startsWith('http')
    ? ogImage
    : `${siteUrl}${ogImage.startsWith('/') ? '' : '/'}${ogImage}`
  : `${siteUrl}/og-image.png`;

const canonicalUrl = canonical || Astro.url.pathname;
const absoluteCanonical = canonicalUrl.startsWith('http')
  ? canonicalUrl
  : `${siteUrl}${canonicalUrl.startsWith('/') ? '' : '/'}${canonicalUrl}`;
---

<meta name="description" content={metaDescription} />
{noindex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow" />
)}
<link rel="canonical" href={absoluteCanonical} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={absoluteCanonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={metaImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="en_US" />

<!-- Article/Book specific OG tags -->
{type === 'book' && author && <meta property="book:author" content={author} />}
{type === 'book' && tags.length > 0 && <meta property="book:tag" content={tags.join(', ')} />}
{publishedAt && <meta property="article:published_time" content={publishedAt} />}
{modifiedAt && <meta property="article:modified_time" content={modifiedAt} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={metaImage} />

<!-- JSON-LD -->
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
